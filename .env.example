# NextAuth Configuration
# Required for SIWE (Sign In With Ethereum) authentication
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Node Environment
# Set to 'development' for local development, 'production' for deployment
NODE_ENV=development

# Application Domain
# Used for constructing absolute URLs
NEXT_PUBLIC_DOMAIN=localhost:3001

# WalletConnect Configuration
# Required for Web3Modal wallet connection functionality
# Get your free project ID from: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Lit Protocol Configuration (deprecated, may be removed in future)
NEXT_PUBLIC_LIT_NETWORK=naga-dev

# OAuth Providers (optional, required only if using OAuth authentication)
# Google OAuth
# Create credentials at: https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# Discord OAuth
# Create application at: https://discord.com/developers/applications
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_discord_client_id_here

